{
  "name": "claude-telegram-topics",
  "version": "0.13.2",
  "description": "Telegram channel for Claude Code with 1 project = 1 forum topic. Concurrent multi-project support via a leader/follower bridge. Clean fork of the official Anthropic Telegram plugin.",
  "license": "Apache-2.0",
  "author": { "name": "2naive", "url": "https://github.com/2naive" },
  "repository": { "type": "git", "url": "git+https://github.com/2naive/claude-telegram-topics.git" },
  "homepage": "https://github.com/2naive/claude-telegram-topics#readme",
  "bugs": { "url": "https://github.com/2naive/claude-telegram-topics/issues" },
  "keywords": [
    "telegram",
    "claude-code",
    "mcp",
    "channel",
    "forum",
    "topics",
    "notifications",
    "remote",
    "mobile",
    "multi-project"
  ],
  "type": "module",
  "bin": "./src/server.ts",
  "scripts": {
    "start": "bun install --no-summary && bun src/server.ts",
    "typecheck": "bun --bun tsc --noEmit",
    "test": "bun test",
    "preflight": "bun scripts/preflight.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "grammy": "^1.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "bun-types": "^1.1.0"
  }
}
